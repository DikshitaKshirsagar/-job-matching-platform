<configuration>
    <property name="LOG_PATTERN" value="{&quot;timestamp&quot;:&quot;%date{ISO8601}&quot;,&quot;level&quot;:&quot;%level&quot;,&quot;thread&quot;:&quot;%thread&quot;,&quot;logger&quot;:&quot;%logger{36}&quot;,&quot;correlationId&quot;:&quot;%X{correlationId}&quot;,&quot;message&quot;:&quot;%msg&quot;}%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <logger name="org.springframework" level="WARN" />
    <logger name="com.jobmatch" level="DEBUG" />
</configuration>
