{
  "info": {
    "name": "AI Job Platform",
    "description": "Complete API collection for the Job Matching Platform. All authenticated endpoints use the JWT token obtained from Login/Register. Includes automated test scripts for CI/CD pipeline.\n\nRun with: newman run collection.json -e environment.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "applicationId",
      "value": ""
    },
    {
      "key": "recruiterToken",
      "value": ""
    },
    {
      "key": "seekerToken",
      "value": ""
    },
    {
      "key": "seekerJobId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Seeker",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register returns 201 and token', function () {",
                  "  pm.response.to.have.status(201);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "  pm.expect(jsonData.data).to.have.property('token');",
                  "  pm.collectionVariables.set('seekerToken', jsonData.data.token);",
                  "  pm.globals.set('seekerToken', jsonData.data.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Seeker\",\n  \"email\": \"seeker_ci@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\",\n  \"role\": \"SEEKER\"\n}"
            }
          }
        },
        {
          "name": "Register Recruiter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register recruiter returns 201 and token', function () {",
                  "  pm.response.to.have.status(201);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "  pm.expect(jsonData.data).to.have.property('token');",
                  "  pm.collectionVariables.set('recruiterToken', jsonData.data.token);",
                  "  pm.collectionVariables.set('token', jsonData.data.token);",
                  "  pm.globals.set('recruiterToken', jsonData.data.token);",
                  "  pm.globals.set('token', jsonData.data.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Recruiter\",\n  \"email\": \"recruiter_ci@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\",\n  \"role\": \"RECRUITER\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login returns 200 and JWT token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "  pm.expect(jsonData.data).to.have.property('token');",
                  "  pm.collectionVariables.set('token', jsonData.data.token);",
                  "  pm.globals.set('token', jsonData.data.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"recruiter_ci@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job (Recruiter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create job returns 201 for recruiter', function () {",
                  "  pm.response.to.have.status(201);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "  pm.expect(jsonData.data).to.have.property('id');",
                  "  pm.collectionVariables.set('jobId', jsonData.data.id);",
                  "  pm.globals.set('jobId', String(jsonData.data.id));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {"key": "token", "value": "{{recruiterToken}}", "type": "string"}
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/jobs",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Software Engineer CI\",\n  \"description\": \"Java developer with Spring Boot experience\",\n  \"company\": \"Tech Corp CI\",\n  \"location\": \"Remote\",\n  \"requiredSkills\": \"Java, Spring Boot, SQL\",\n  \"jobType\": \"FULL_TIME\",\n  \"salaryMin\": 80000,\n  \"salaryMax\": 120000\n}"
            }
          }
        },
        {
          "name": "Get All Jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get all jobs returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "  pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs?page=0&size=10&sortBy=createdAt&direction=DESC",
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"},
                {"key": "sortBy", "value": "createdAt"},
                {"key": "direction", "value": "DESC"}
              ]
            }
          }
        },
        {
          "name": "Search Jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Search jobs returns filtered results', function () {",
                  "  pm.response.to.have.status(200);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs?keyword=Java&location=Remote&page=0&size=10",
              "query": [
                {"key": "keyword", "value": "Java"},
                {"key": "location", "value": "Remote"},
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Get Job By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get job by ID returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "  pm.expect(jsonData.data).to.have.property('id');",
                  "  pm.expect(jsonData.data).to.have.property('title');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}"
          }
        },
        {
          "name": "Update Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Update job returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {"key": "token", "value": "{{recruiterToken}}", "type": "string"}
              ]
            },
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Software Engineer CI\",\n  \"salaryMin\": 100000,\n  \"salaryMax\": 150000\n}"
            }
          }
        },
        {
          "name": "Delete Job (Wrong Owner - Seeker) -> 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Delete job with wrong owner returns 403', function () {",
                  "  pm.expect(pm.response.code).to.equal(403);",
                  "});"
                ]
