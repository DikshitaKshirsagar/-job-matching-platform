            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {"key": "token", "value": "{{seekerToken}}", "type": "string"}
              ]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}"
          }
        },
