          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Match endpoint returns 200 with score', function () {",
                  "  pm.response.to.have.status(200);",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('matchScore');",
                  "  pm.expect(jsonData.matchScore).to.be.within(0, 100);",
                  "  pm.expect(jsonData).to.have.property('skillsMatched');",
                  "  pm.expect(jsonData).to.have.property('skillsMissing');",
                  "  pm.expect(jsonData.skillsMatched).to.be.an('array');",
                  "  pm.expect(jsonData.skillsMissing).to.be.an('array');",
                  "});"
                ]
